package org.drools.generated;

declare LoanApplication
    creditScore: int
    employmentYears: int
    loanAmount: double
    annualSalary: double
    decision: String
end

rule "Approve Loan"
when
    $loan : LoanApplication(creditScore > 700, employmentYears >= 2, loanAmount < 5 * annualSalary)
then
    modify($loan) {
        setDecision("APPROVED")
    }
end

rule "Escalate to Human Review"
when
    $loan : LoanApplication(creditScore >= 650 && creditScore <= 700, employmentYears >= 2, loanAmount < 5 * annualSalary)
then
    modify($loan) {
        setDecision("REVIEW")
    }
end

rule "Deny Loan"
when
    $loan : LoanApplication(creditScore < 650 || employmentYears < 2 || loanAmount >= 5 * annualSalary)
then
    modify($loan) {
        setDecision("DENIED")
    }
end