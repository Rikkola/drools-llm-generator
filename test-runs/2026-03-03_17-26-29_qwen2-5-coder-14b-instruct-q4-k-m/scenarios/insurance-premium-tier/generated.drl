package org.drools.generated;

declare InsuranceApplicant
    applicantId : String
    age : int
    smoker : boolean
    premiumTier : String
end

rule "Assign Premium Tier for Smokers"
when
    $applicant : InsuranceApplicant(smoker == true)
then
    modify($applicant) {
        setPremiumTier("HIGH")
    }
end

rule "Assign Premium Tier for Non-Smokers Over 50"
when
    $applicant : InsuranceApplicant(smoker == false, age > 50)
then
    modify($applicant) {
        setPremiumTier("MEDIUM")
    }
end

rule "Assign Premium Tier for Non-Smokers 50 or Under"
when
    $applicant : InsuranceApplicant(smoker == false, age <= 50)
then
    modify($applicant) {
        setPremiumTier("LOW")
    }
end