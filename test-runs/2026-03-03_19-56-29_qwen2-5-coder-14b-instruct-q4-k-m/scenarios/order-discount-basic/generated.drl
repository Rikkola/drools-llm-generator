package org.drools.generated;

declare Order
    orderId: String
    total: double
    discountPercent: int
    discountApplied: boolean
end

rule "Apply Discount for High Total"
when
    $order : Order(total > 100.0)
then
    modify($order) {
        setDiscountPercent(10),
        setDiscountApplied(true)
    }
end