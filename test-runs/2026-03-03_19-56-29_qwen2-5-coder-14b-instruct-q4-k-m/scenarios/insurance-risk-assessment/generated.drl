package org.drools.generated;

declare Applicant
    age: int
    smoker: boolean
    bmi: double
    riskLevel: String
end

rule "High Risk Assessment"
when
    $applicant : Applicant(age > 60 || smoker == true || bmi > 30)
then
    modify($applicant) { setRiskLevel("HIGH") }
end

rule "Medium Risk Assessment"
when
    $applicant : Applicant(age >= 40 && age <= 60 || (bmi >= 25 && bmi <= 30))
then
    modify($applicant) { setRiskLevel("MEDIUM") }
end

rule "Low Risk Assessment"
when
    $applicant : Applicant(age < 40 && bmi < 25)
then
    modify($applicant) { setRiskLevel("LOW") }
end