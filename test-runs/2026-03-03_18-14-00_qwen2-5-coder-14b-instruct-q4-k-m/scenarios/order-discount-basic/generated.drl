package org.drools.generated;

declare Order
    orderId : String
    total : double
    discountPercent : int
    discountApplied : boolean
end

rule "Apply Discount to High Value Orders"
when
    $order : Order(total > 100.0)
then
    modify($order) {
        setDiscountPercent(10),
        setDiscountApplied(true)
    }
end