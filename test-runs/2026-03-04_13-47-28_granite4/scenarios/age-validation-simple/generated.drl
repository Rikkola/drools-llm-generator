package org.drools.generated;

declare Person
    name : String
    age : int
    result : String
end

rule "Determine Adult Status"
salience 100
when
    $p : Person(age >= 18, result == null)
then
    modify($p) { setResult("adult") }
end

rule "Determine Minor Status"
salience 90
when
    $p : Person(age < 18, result == null)
then
    modify($p) { setResult("minor") }
end