package org.drools.generated;

declare Person
    name : String
    age : int
    result : String
end

rule "Determine Adult"
when
    $p : Person(age >= 18)
then
    modify($p) { setResult("adult") }
end

rule "Determine Minor"
when
    $p : Person(age < 18)
then
    modify($p) { setResult("minor") }
end