package org.drools.generated;

declare Person
    name : String
    age : int
    adult : boolean
end

rule "Set Adult True"
when
    $p : Person(age >= 18, adult == false)
then
    modify($p) { setAdult(true) }
end

rule "Set Adult False"
when
    $p : Person(age < 18, adult == true)
then
    modify($p) { setAdult(false) }
end