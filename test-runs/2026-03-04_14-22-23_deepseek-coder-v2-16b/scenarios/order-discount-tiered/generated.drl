package org.drools.generated;

declare Order
    orderId : String
    total : double
    discountPercent : int
    discountTier : String
end

rule "Apply Premium Tier Discount"
salience 100
when
    $o : Order(total >= 200, discountTier == "NONE")
then
    modify($o) { setDiscountPercent(15); setDiscountTier("PREMIUM") }
end

rule "Apply Gold Tier Discount"
salience 90
when
    $o : Order(total >= 100 && total < 200, discountTier == "NONE")
then
    modify($o) { setDiscountPercent(10); setDiscountTier("GOLD") }
end

rule "Apply Silver Tier Discount"
salience 80
when
    $o : Order(total >= 50 && total < 100, discountTier == "NONE")
then
    modify($o) { setDiscountPercent(5); setDiscountTier("SILVER") }
end