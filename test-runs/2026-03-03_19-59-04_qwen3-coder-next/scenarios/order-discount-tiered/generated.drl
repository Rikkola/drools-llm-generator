package org.drools.generated;

declare Order
    orderId : String
    total : double
    discountPercent : int
    discountTier : String
end

rule "Premium Tier Discount"
when
    $order : Order( discountTier == "NONE", total >= 200 )
then
    modify( $order ) { setDiscountPercent( 15 ), setDiscountTier( "PREMIUM" ) }
end

rule "Gold Tier Discount"
when
    $order : Order( discountTier == "NONE", total >= 100, total < 200 )
then
    modify( $order ) { setDiscountPercent( 10 ), setDiscountTier( "GOLD" ) }
end

rule "Silver Tier Discount"
when
    $order : Order( discountTier == "NONE", total >= 50, total < 100 )
then
    modify( $order ) { setDiscountPercent( 5 ), setDiscountTier( "SILVER" ) }
end