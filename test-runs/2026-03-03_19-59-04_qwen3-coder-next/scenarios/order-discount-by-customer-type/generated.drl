package org.drools.generated;

declare Order
    customerType : String
    orderTotal : double
    discountPercent : int
end

rule "Premium Customer - Order > 1000"
    when
        $o : Order( customerType == "premium", orderTotal > 1000 )
    then
        modify( $o ) { setDiscountPercent(20) }
end

rule "Premium Customer - Order 500 to 1000"
    when
        $o : Order( customerType == "premium", orderTotal >= 500, orderTotal <= 1000 )
    then
        modify( $o ) { setDiscountPercent(15) }
end

rule "Premium Customer - Order < 500"
    when
        $o : Order( customerType == "premium", orderTotal < 500 )
    then
        modify( $o ) { setDiscountPercent(10) }
end

rule "Regular Customer - Order > 1000"
    when
        $o : Order( customerType == "regular", orderTotal > 1000 )
    then
        modify( $o ) { setDiscountPercent(10) }
end

rule "Regular Customer - Order 500 to 1000"
    when
        $o : Order( customerType == "regular", orderTotal >= 500, orderTotal <= 1000 )
    then
        modify( $o ) { setDiscountPercent(5) }
end

rule "Regular Customer - Order < 500"
    when
        $o : Order( customerType == "regular", orderTotal < 500 )
    then
        modify( $o ) { setDiscountPercent(0) }
end