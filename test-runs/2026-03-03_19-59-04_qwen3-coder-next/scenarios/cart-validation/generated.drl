package org.drools.generated;

declare ShoppingCart
    cartId: String
    hasOutOfStockItem: boolean
    allItemsSameCategory: boolean
    maxQuantityOfSingleItem: int
    rejected: boolean
    rejectionReason: String
    sameCategoryDiscount: int
    flaggedForReview: boolean
end

rule "Reject cart if has out of stock item"
    when
        $cart : ShoppingCart( hasOutOfStockItem == true )
    then
        modify( $cart ) { setRejected( true ), setRejectionReason( "OUT_OF_STOCK" ) }
end

rule "Apply same category discount"
    when
        $cart : ShoppingCart( allItemsSameCategory == true )
    then
        modify( $cart ) { setSameCategoryDiscount( 10 ) }
end

rule "Flag cart for review if max quantity exceeds 10"
    when
        $cart : ShoppingCart( maxQuantityOfSingleItem > 10 )
    then
        modify( $cart ) { setFlaggedForReview( true ) }
end