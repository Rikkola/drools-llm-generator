package org.drools.generated;

declare Student
    studentId : String
    name : String
    score : int
    grade : String
end

rule "Grade A"
when
    $s : Student(score >= 90)
then
    modify($s) { setGrade("A") }
end

rule "Grade B"
when
    $s : Student(score >= 80, score < 90)
then
    modify($s) { setGrade("B") }
end

rule "Grade C"
when
    $s : Student(score >= 70, score < 80)
then
    modify($s) { setGrade("C") }
end

rule "Grade D"
when
    $s : Student(score >= 60, score < 70)
then
    modify($s) { setGrade("D") }
end

rule "Grade F"
when
    $s : Student(score < 60)
then
    modify($s) { setGrade("F") }
end