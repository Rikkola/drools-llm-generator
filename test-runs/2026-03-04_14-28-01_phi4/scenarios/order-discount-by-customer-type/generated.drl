package org.drools.generated;

declare Order
    customerType : String
    orderTotal : double
    discountPercent : int
end

rule "Premium Customer High Order Discount"
salience 100
when
    $o : Order(customerType == "premium", orderTotal > 1000, discountPercent == 0)
then
    modify($o) { setDiscountPercent(20) }
end

rule "Premium Customer Medium Order Discount"
salience 90
when
    $o : Order(customerType == "premium", orderTotal >= 500, orderTotal <= 1000, discountPercent == 0)
then
    modify($o) { setDiscountPercent(15) }
end

rule "Premium Customer Low Order Discount"
salience 80
when
    $o : Order(customerType == "premium", discountPercent == 0)
then
    modify($o) { setDiscountPercent(10) }
end

rule "Regular Customer High Order Discount"
salience 70
when
    $o : Order(customerType == "regular", orderTotal > 1000, discountPercent == 0)
then
    modify($o) { setDiscountPercent(10) }
end

rule "Regular Customer Medium Order Discount"
salience 60
when
    $o : Order(customerType == "regular", orderTotal >= 500, orderTotal <= 1000, discountPercent == 0)
then
    modify($o) { setDiscountPercent(5) }
end

rule "Regular Customer Low Order No Discount"
salience 50
when
    $o : Order(customerType == "regular", discountPercent == 0)
then
    // No action needed as the default is no discount (0%)
end