package org.drools.generated;

declare Student
    studentId : String
    name : String
    score : int
    grade : String
end

rule "Assign Grade A"
salience 100
when
    $s : Student(score >= 90, grade == null)
then
    modify($s) { setGrade("A") }
end

rule "Assign Grade B"
salience 90
when
    $s : Student(score >= 80, score < 90, grade == null)
then
    modify($s) { setGrade("B") }
end

rule "Assign Grade C"
salience 80
when
    $s : Student(score >= 70, score < 80, grade == null)
then
    modify($s) { setGrade("C") }
end

rule "Assign Grade D"
salience 70
when
    $s : Student(score >= 60, score < 70, grade == null)
then
    modify($s) { setGrade("D") }
end

rule "Assign Grade F"
salience 10
when
    $s : Student(score < 60, grade == null)
then
    modify($s) { setGrade("F") }
end