package org.drools.generated;

declare Invoice
    invoiceId : String
    subtotal : double
    taxAmount : double
    total : double
end

rule "Calculate Tax and Total"
when
    $invoice : Invoice(subtotal > 0)
then
    double taxAmount = $invoice.getSubtotal() * 0.1;
    modify($invoice) {
        setTaxAmount(taxAmount),
        setTotal($invoice.getSubtotal() + taxAmount)
    }
end