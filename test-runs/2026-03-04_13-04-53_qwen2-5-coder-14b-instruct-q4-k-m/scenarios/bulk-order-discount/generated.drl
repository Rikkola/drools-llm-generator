package org.drools.generated;

declare Customer
    customerId : String
    ordersThisMonth : int
    totalSpentThisMonth : double
    isVip : boolean
    discountPercent : int
end

rule "Upgrade to VIP and Apply Discount"
salience 100
when
    $c : Customer(ordersThisMonth > 5, totalSpentThisMonth > 5000.0, isVip == false)
then
    modify($c) {
        setIsVip(true),
        setDiscountPercent(25)
    }
end

rule "No Change - Not Enough Orders"
salience 90
when
    $c : Customer(ordersThisMonth <= 5, totalSpentThisMonth > 5000.0, isVip == false)
then
    // No action needed, already not VIP
end

rule "No Change - Not Enough Spent"
salience 80
when
    $c : Customer(ordersThisMonth > 5, totalSpentThisMonth <= 5000.0, isVip == false)
then
    // No action needed, already not VIP
end

rule "No Change - Already VIP"
salience 70
when
    $c : Customer(isVip == true)
then
    // No action needed, already VIP
end