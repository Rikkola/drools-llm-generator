package org.drools.generated;

declare Customer
    customerId : String
    ordersThisMonth : int
    totalSpentThisMonth : double
    isVip : boolean
    discountPercent : int
end

rule "Upgrade to VIP and Apply Discount"
salience 100
when
    $c : Customer(ordersThisMonth > 5, totalSpentThisMonth > 5000, isVip == false)
then
    modify($c) {
        setIsVip(true),
        setDiscountPercent(25)
    }
end

rule "No VIP Upgrade - Not Enough Orders"
salience 90
when
    $c : Customer(ordersThisMonth <= 5, totalSpentThisMonth > 5000, isVip == false)
then
    modify($c) {
        setIsVip(false),
        setDiscountPercent(0)
    }
end

rule "No VIP Upgrade - Not Enough Spent"
salience 80
when
    $c : Customer(ordersThisMonth > 5, totalSpentThisMonth <= 5000, isVip == false)
then
    modify($c) {
        setIsVip(false),
        setDiscountPercent(0)
    }
end

rule "No VIP Upgrade - Already VIP"
salience 70
when
    $c : Customer(isVip == true)
then
    // No changes needed, already VIP
end