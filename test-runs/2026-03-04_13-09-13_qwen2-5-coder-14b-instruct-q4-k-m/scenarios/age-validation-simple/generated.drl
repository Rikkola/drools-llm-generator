package org.drools.generated;

declare Person
    name : String
    age : int
    result : String
end

rule "Set Adult"
salience 100
when
    $p : Person(age >= 18, result == "unknown")
then
    modify($p) { setResult("adult") }
end

rule "Set Minor"
salience 90
when
    $p : Person(age < 18, result == "unknown")
then
    modify($p) { setResult("minor") }
end