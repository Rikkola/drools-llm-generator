package org.drools.generated;

declare Shipment
    shipmentId : String
    isHazardous : boolean
    isPrimeCustomer : boolean
    orderTotal : double
    weightLbs : double
    shippingMethod : String
end

rule "Hazardous Shipping - Highest Priority"
salience 100
when
    $s : Shipment(
        shippingMethod == "PENDING",
        isHazardous == true
    )
then
    modify($s) {
        setShippingMethod("SPECIALIZED")
    }
end

rule "Prime Customer Express Free"
salience 90
when
    $s : Shipment(
        shippingMethod == "PENDING",
        isPrimeCustomer == true,
        orderTotal > 25.0
    )
then
    modify($s) {
        setShippingMethod("EXPRESS_FREE")
    }
end

rule "Heavy Freight Shipping"
salience 80
when
    $s : Shipment(
        shippingMethod == "PENDING",
        weightLbs > 50.0
    )
then
    modify($s) {
        setShippingMethod("FREIGHT")
    }
end

rule "Default Standard Shipping"
salience 10
when
    $s : Shipment(shippingMethod == "PENDING")
then
    modify($s) {
        setShippingMethod("STANDARD")
    }
end