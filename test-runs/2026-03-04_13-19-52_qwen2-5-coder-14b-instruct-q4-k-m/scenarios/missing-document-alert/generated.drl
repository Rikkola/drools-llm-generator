package org.drools.generated;

declare Application
    applicationId : String
    applicantAge : int
    loanAmount : double
    hasIdentityDocument : boolean
    hasIncomeVerification : boolean
    incomplete : boolean
    missingDocumentType : String
end

rule "Flag Incomplete - Adult Missing ID"
salience 100
when
    $app : Application(applicantAge > 18, hasIdentityDocument == false, incomplete == false)
then
    modify($app) { setIncomplete(true), setMissingDocumentType("ID") }
end

rule "Flag Incomplete - High Loan Missing Income Verification"
salience 90
when
    $app : Application(loanAmount > 100000, hasIncomeVerification == false, incomplete == false)
then
    modify($app) { setIncomplete(true), setMissingDocumentType("INCOME_VERIFICATION") }
end

rule "Ensure Complete Application"
salience 80
when
    $app : Application(applicantAge <= 18, hasIdentityDocument == false, hasIncomeVerification == false, incomplete == true)
then
    modify($app) { setIncomplete(false), setMissingDocumentType("none") }
end

rule "Ensure Complete Application - Minor Without ID"
salience 70
when
    $app : Application(applicantAge <= 18, hasIdentityDocument == false, hasIncomeVerification == true, incomplete == true)
then
    modify($app) { setIncomplete(false), setMissingDocumentType("none") }
end

rule "Ensure Complete Application - Minor Without Income Verification"
salience 60
when
    $app : Application(applicantAge <= 18, hasIdentityDocument == true, hasIncomeVerification == false, incomplete == true)
then
    modify($app) { setIncomplete(false), setMissingDocumentType("none") }
end

rule "Ensure Complete Application - Minor With All Documents"
salience 50
when
    $app : Application(applicantAge <= 18, hasIdentityDocument == true, hasIncomeVerification == true, incomplete == true)
then
    modify($app) { setIncomplete(false), setMissingDocumentType("none") }
end