package org.drools.generated;

declare Invoice
    invoiceId : String
    subtotal : double
    taxAmount : double
    total : double
end

rule "Calculate Tax"
when
    $invoice : Invoice(subtotal > 0, taxAmount == 0.0)
then
    modify($invoice) {
        setTaxAmount($invoice.getSubtotal() * 0.1),
        setTotal($invoice.getSubtotal() + $invoice.getTaxAmount())
    }
end