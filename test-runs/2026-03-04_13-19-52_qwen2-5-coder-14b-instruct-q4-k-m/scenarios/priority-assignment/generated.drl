package org.drools.generated;

declare Ticket
    ticketId : String
    severity : String
    priority : int
end

rule "Set Priority for Critical Severity"
salience 100
when
    $ticket : Ticket(severity == "CRITICAL", priority == 0)
then
    modify($ticket) { setPriority(1) }
end

rule "Set Priority for High Severity"
salience 90
when
    $ticket : Ticket(severity == "HIGH", priority == 0)
then
    modify($ticket) { setPriority(2) }
end

rule "Set Priority for Medium Severity"
salience 80
when
    $ticket : Ticket(severity == "MEDIUM", priority == 0)
then
    modify($ticket) { setPriority(3) }
end

rule "Set Priority for Low Severity"
salience 70
when
    $ticket : Ticket(severity == "LOW", priority == 0)
then
    modify($ticket) { setPriority(4) }
end