package org.drools.generated;

declare LoanApplication
    applicantId : String
    income : double
    creditScore : int
    employed : boolean
    eligible : boolean
end

rule "Check Eligibility"
when
    $loan : LoanApplication(income >= 50000, creditScore >= 700, employed == true, eligible == false)
then
    modify($loan) { setEligible(true) }
end