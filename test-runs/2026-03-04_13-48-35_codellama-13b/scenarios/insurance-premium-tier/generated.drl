package org.drools.generated;

declare InsuranceApplicant
    applicantId : String
    age : int
    smoker : boolean
    premiumTier : String
end

rule "Smoker High Risk"
salience 100
when
    $a : InsuranceApplicant(smoker == true, premiumTier == null)
then
    modify($a) { setPremiumTier("HIGH") }
end

rule "Non-Smoker High Risk"
salience 90
when
    $a : InsuranceApplicant(smoker == false, age > 50, premiumTier == null)
then
    modify($a) { setPremiumTier("MEDIUM") }
end

rule "Non-Smoker Low Risk"
salience 10
when
    $a : InsuranceApplicant(smoker == false, age <= 50, premiumTier == null)
then
    modify($a) { setPremiumTier("LOW") }
end