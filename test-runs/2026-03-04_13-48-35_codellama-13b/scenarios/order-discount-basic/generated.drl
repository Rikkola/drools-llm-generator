package org.drools.generated;

declare Order
    orderId : String
    total : double
    discountPercent : int
    discountApplied : boolean
end

rule "Qualifying Discount"
salience 100
when
    $o : Order(total > 100.0, discountApplied == false)
then
    modify($o) {
        setDiscountPercent(10),
        setDiscountApplied(true)
    }
end