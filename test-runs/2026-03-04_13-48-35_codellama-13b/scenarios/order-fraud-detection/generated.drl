[PYTHON]
# DRL - Decision Rule Language
# Generated by: INSTANT

package org.drools.generated;

import java.util.*;

global List list;

declare Order
    orderId : String
    orderTotal : double
    accountAgeDays : int
    shippingAddress : String
    billingAddress : String
    failedPaymentAttempts : int
    suspicious : boolean
    suspiciousReason : String
end

rule "Suspicious Order - New Account High Value"
when
    $o : Order(orderTotal > 500, accountAgeDays < 7, suspicious == false)
then
    modify($o) { setSuspicious(true), setSuspiciousReason("New Account High Value") }
end

rule "Suspicious Order - Address Mismatch High Value"
when
    $o : Order(orderTotal > 1000, shippingAddress != billingAddress, suspicious == false)
then
    modify($o) { setSuspicious(true), setSuspiciousReason("Address Mismatch High Value") }
end

rule "Suspicious Order - Multiple Failed Payments"
when
    $o : Order(failedPaymentAttempts > 3, suspicious == false)
then
    modify($o) { setSuspicious(true), setSuspiciousReason("Multiple Failed Payments") }
end

rule "Normal Order"
when
    $o : Order(suspicious == false)
then
    list.add($o);
end
[/PYTHON]