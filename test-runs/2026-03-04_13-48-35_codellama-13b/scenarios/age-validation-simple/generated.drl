package org.drools.generated;

declare Person
    name : String
    age : int
    result : String
end

rule "Adult"
salience 100
when
    $p : Person(age >= 18, result == null)
then
    modify($p) { setResult("adult") }
end

rule "Minor"
salience 50
when
    $p : Person(age < 18, result == null)
then
    modify($p) { setResult("minor") }
end