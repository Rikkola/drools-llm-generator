package org.drools.generated;

declare Student
    studentId : String
    name : String
    score : int
    grade : String
end

rule "Assign Grade A"
when
    $s : Student(score >= 90)
then
    modify($s) { setGrade("A") }
end

rule "Assign Grade B"
when
    $s : Student(score >= 80, score < 90)
then
    modify($s) { setGrade("B") }
end

rule "Assign Grade C"
when
    $s : Student(score >= 70, score < 80)
then
    modify($s) { setGrade("C") }
end

rule "Assign Grade D"
when
    $s : Student(score >= 60, score < 70)
then
    modify($s) { setGrade("D") }
end

rule "Assign Grade F"
when
    $s : Student(score < 60)
then
    modify($s) { setGrade("F") }
end