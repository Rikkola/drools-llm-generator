package org.drools.generated;

declare Person
    name : String
    age : int
    result : String
end

rule "Person is Adult"
    when
        $p : Person( age >= 18, result == "unknown" )
    then
        modify( $p ) { setResult( "adult" ) }
end

rule "Person is Minor"
    when
        $p : Person( age < 18, result == "unknown" )
    then
        modify( $p ) { setResult( "minor" ) }
end