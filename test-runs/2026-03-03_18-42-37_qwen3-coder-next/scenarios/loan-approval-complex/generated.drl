package org.drools.generated;

declare LoanApplication
    creditScore : int
    employmentYears : int
    loanAmount : double
    annualSalary : double
    decision : String
end

rule "Approve Loan - High Credit Score"
    when
        $app : LoanApplication( 
            creditScore > 700,
            employmentYears >= 2,
            loanAmount < (5 * annualSalary),
            decision == "PENDING"
        )
    then
        modify($app) { setDecision("APPROVED") };
end

rule "Escalate to Human Review - Medium Credit Score"
    when
        $app : LoanApplication( 
            creditScore >= 650 && creditScore <= 700,
            decision == "PENDING"
        )
    then
        modify($app) { setDecision("REVIEW_REQUIRED") };
end

rule "Deny Loan - Low Credit Score"
    when
        $app : LoanApplication( 
            creditScore < 650,
            decision == "PENDING"
        )
    then
        modify($app) { setDecision("DENIED") };
end